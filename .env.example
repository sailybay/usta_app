# ─── Usta App — Environment Variables Template ───────────────────────────────
# Скопируйте этот файл в .env и заполните своими ключами:
#   cp .env.example .env
#
# Этот файл (.env.example) БЕЗОПАСНО коммитить — реальных ключей нет.
# Файл .env добавлен в .gitignore — он никогда не попадёт в репозиторий.

# Groq API Key — получить на: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
