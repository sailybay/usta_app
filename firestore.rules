rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isWorker() {
      return isAuthenticated() && getUserData().role == 'worker';
    }

    function isClient() {
      return isAuthenticated() && getUserData().role == 'client';
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    // ── Users Collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read profiles (for service discovery)
      allow read: if isAuthenticated();
      // Only the owner can write their profile
      allow write: if isOwner(userId);
      // Admins have full access
      allow read, write: if isAdmin();
    }

    // ── Services Collection ───────────────────────────────────────────────────
    match /services/{serviceId} {
      // All authenticated users can read services
      allow read: if isAuthenticated();
      // Only workers can create/update their own services
      allow create: if isWorker() && request.resource.data.workerId == request.auth.uid;
      allow update: if isWorker() && resource.data.workerId == request.auth.uid;
      allow delete: if isWorker() && resource.data.workerId == request.auth.uid
                    || isAdmin();
    }

    // ── Orders Collection ─────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Clients see their own orders; workers see orders assigned to them
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.workerId == request.auth.uid ||
                   isAdmin());

      // Clients can create orders where they are the client
      allow create: if isClient() &&
                    request.resource.data.clientId == request.auth.uid;

      // Status updates: only the assigned worker or client (for cancel)
      allow update: if isAuthenticated() &&
                    (resource.data.workerId == request.auth.uid ||
                     resource.data.clientId == request.auth.uid ||
                     isAdmin());

      allow delete: if isAdmin();
    }

    // ── Reviews Collection ────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      // Only the client of the order can write a review
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Payments Collection ───────────────────────────────────────────────────
    match /payments/{paymentId} {
      // Only the involved parties can read payment data
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.workerId == request.auth.uid ||
                   isAdmin());

      // Payments are created/updated by Cloud Functions (server-side) only
      // Client-side creation is restricted to client's own payments
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Chats Collection ──────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() &&
                         request.auth.uid in resource.data.participantIds;

      // Chat metadata update for unread count
      allow update: if isAuthenticated();

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                    request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if isAuthenticated() &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds &&
                      request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ── Categories Collection ─────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
